---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout
  title="About Us — TED Talk Finder | AI-Powered TED Talk Discovery"
  description="Learn about TED Talk Finder — the AI-powered tool built to help you discover the best TED Talks on any topic. Our mission is to make ideas worth spreading more accessible."
  canonicalUrl="https://tedtalksfinder.com/about"
>
  <!-- Nav -->
  <Header activePage="about" />

  <!-- Hero -->
  <section class="bg-black text-white py-16 sm:py-24 px-4 sm:px-6 md:px-12">
    <div class="max-w-4xl mx-auto">
      <p class="text-[10px] sm:text-xs font-bold uppercase tracking-widest text-[#EB0028] mb-4">About Us</p>
      <h1 class="text-3xl sm:text-5xl md:text-6xl font-extrabold uppercase tracking-tight leading-none mb-6">
        Making Ideas<br /><span class="text-[#EB0028]">Worth Spreading</span><br />Accessible to All
      </h1>
      <p class="text-sm sm:text-base text-gray-400 leading-relaxed max-w-2xl">
        TED Talk Finder was built with one goal: make the enormous library of TED Talks genuinely searchable, 
        filterable, and explorable so the right talk reaches the right person at the right moment.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <main class="bg-white py-12 sm:py-20 px-4 sm:px-6 md:px-12">
    <div class="max-w-4xl mx-auto space-y-16">

      <!-- Mission -->
      <section>
        <div class="border-b border-gray-200 pb-4 mb-8">
          <p class="text-[10px] font-bold uppercase tracking-widest text-[#EB0028] mb-2">Our Mission</p>
          <h2 class="text-2xl sm:text-3xl font-extrabold uppercase tracking-tight text-black">Why We Built This</h2>
        </div>
        <div class="prose max-w-none text-sm sm:text-base text-gray-700 leading-relaxed space-y-4">
          <p>
            TED has published over 4,000 talks spanning decades of human knowledge — from Nobel laureates and 
            scientists to artists, entrepreneurs, and community builders. Yet finding the <em>right</em> talk on a 
            topic you care about has always been harder than it should be.
          </p>
          <p>
            That is the problem TED Talk Finder solves. Using the power of modern AI — specifically Google Gemini 
            and Grok — we generate a curated shortlist of the most relevant TED talks for any topic you enter. 
            We then verify every suggestion against the official TED YouTube channel in real-time, ensuring you 
            only ever see genuine, full-length talks (no shorts, no trailers, no sponsored clips).
          </p>
          <p>
            The result: a premium, distraction-free discovery experience that puts the world's best ideas at 
            your fingertips in seconds.
          </p>
        </div>
      </section>

      <!-- How It Works -->
      <section>
        <div class="border-b border-gray-200 pb-4 mb-8">
          <p class="text-[10px] font-bold uppercase tracking-widest text-[#EB0028] mb-2">The Technology</p>
          <h2 class="text-2xl sm:text-3xl font-extrabold uppercase tracking-tight text-black">How TED Talk Finder Works</h2>
        </div>
        <div class="grid sm:grid-cols-3 gap-6 sm:gap-8">
          <div class="border-t-2 border-[#EB0028] pt-4">
            <div class="text-2xl font-extrabold text-[#EB0028] mb-2">01</div>
            <h3 class="text-sm font-extrabold uppercase tracking-wide text-black mb-2">AI Curation</h3>
            <p class="text-xs text-gray-600 leading-relaxed">
              You enter a topic. Our AI (Google Gemini + Grok fallback) analyses your query and recommends the 
              12 most relevant, high-quality long-form TED talks — with strict instructions to only include 
              talks where that topic is the primary focus.
            </p>
          </div>
          <div class="border-t-2 border-[#EB0028] pt-4">
            <div class="text-2xl font-extrabold text-[#EB0028] mb-2">02</div>
            <h3 class="text-sm font-extrabold uppercase tracking-wide text-black mb-2">YouTube Verification</h3>
            <p class="text-xs text-gray-600 leading-relaxed">
              Every AI suggestion is cross-checked against the official TED YouTube channel using the YouTube 
              Data API v3. Videos under 2 minutes (Shorts, trailers, clips) are automatically excluded. 
              Only verified full-length talks make it to your screen.
            </p>
          </div>
          <div class="border-t-2 border-[#EB0028] pt-4">
            <div class="text-2xl font-extrabold text-[#EB0028] mb-2">03</div>
            <h3 class="text-sm font-extrabold uppercase tracking-wide text-black mb-2">Smart Caching</h3>
            <p class="text-xs text-gray-600 leading-relaxed">
              Popular searches are cached in-memory so repeat queries return instantly without consuming API 
              quota. Multiple API key rotation ensures maximum uptime even during high traffic periods.
            </p>
          </div>
        </div>
      </section>

      <!-- Values -->
      <section>
        <div class="border-b border-gray-200 pb-4 mb-8">
          <p class="text-[10px] font-bold uppercase tracking-widest text-[#EB0028] mb-2">Our Principles</p>
          <h2 class="text-2xl sm:text-3xl font-extrabold uppercase tracking-tight text-black">What We Stand For</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="bg-gray-50 p-6">
            <h3 class="text-sm font-extrabold uppercase tracking-wide text-black mb-2">🔍 Accuracy First</h3>
            <p class="text-xs text-gray-600 leading-relaxed">
              We never show unverified results. Every talk is confirmed to exist on the official TED YouTube channel 
              before being displayed to users.
            </p>
          </div>
          <div class="bg-gray-50 p-6">
            <h3 class="text-sm font-extrabold uppercase tracking-wide text-black mb-2">🆓 Always Free</h3>
            <p class="text-xs text-gray-600 leading-relaxed">
              TED Talk Finder is completely free to use with no account required. We believe access to great 
              ideas should have no paywall.
            </p>
          </div>
          <div class="bg-gray-50 p-6">
            <h3 class="text-sm font-extrabold uppercase tracking-wide text-black mb-2">🚫 No Clutter</h3>
            <p class="text-xs text-gray-600 leading-relaxed">
              No YouTube Shorts, no ads, no irrelevant recommendations. Pure, curated, full-length TED Talks 
              matched to your topic.
            </p>
          </div>
          <div class="bg-gray-50 p-6">
            <h3 class="text-sm font-extrabold uppercase tracking-wide text-black mb-2">📖 Open Knowledge</h3>
            <p class="text-xs text-gray-600 leading-relaxed">
              All talks are sourced from TED's publicly available YouTube library. We are a fan-built discovery 
              tool and are not affiliated with TED Conferences LLC.
            </p>
          </div>
        </div>
      </section>

      <!-- Tech Stack -->
      <section>
        <div class="border-b border-gray-200 pb-4 mb-8">
          <p class="text-[10px] font-bold uppercase tracking-widest text-[#EB0028] mb-2">Built With</p>
          <h2 class="text-2xl sm:text-3xl font-extrabold uppercase tracking-tight text-black">Our Tech Stack</h2>
        </div>
        <div class="flex flex-wrap gap-3">
          {["Astro", "Tailwind CSS v4", "Node.js", "Express", "Google Gemini AI", "xAI Grok", "YouTube Data API v3"].map(tech => (
            <span class="border border-gray-300 text-xs font-bold uppercase tracking-wider text-gray-700 px-4 py-2 hover:border-[#EB0028] hover:text-[#EB0028] transition-colors">
              {tech}
            </span>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="bg-black text-white p-8 sm:p-12 text-center">
        <p class="text-[10px] font-bold uppercase tracking-widest text-[#EB0028] mb-4">Get Started</p>
        <h2 class="text-2xl sm:text-3xl font-extrabold uppercase tracking-tight mb-4">Ready to Find Your Next TED Talk?</h2>
        <p class="text-sm text-gray-400 mb-8 max-w-lg mx-auto">
          Type any topic — leadership, creativity, happiness, climate change — and let our AI find the perfect talk for you.
        </p>
        <a
          href="/"
          class="inline-block bg-[#EB0028] text-white font-extrabold uppercase tracking-widest text-xs sm:text-sm px-8 py-4 hover:bg-[#c40020] transition-colors duration-150"
        >
          Find Talks Now
        </a>
      </section>

    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-black text-white py-10 px-4 sm:py-12 sm:px-6 md:px-12 border-t border-gray-900">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center text-[10px] sm:text-xs text-gray-600 gap-4 text-center sm:text-left">
      <div>&copy; 2026 TED Talk Finder. Built with Astro &amp; Tailwind CSS v4.</div>
      <div class="flex flex-wrap justify-center gap-3 sm:gap-4">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <a href="/about" class="hover:text-white transition-colors">About</a>
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms-and-conditions" class="hover:text-white transition-colors">Terms</a>
        <a href="/contact" class="hover:text-white transition-colors">Contact</a>
      </div>
    </div>
  </footer>
</Layout>
