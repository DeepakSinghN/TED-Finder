        </ul>
      </div>
      <div>
        <h4
          class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-4"
        >
          API Caching
        </h4>
        <ul class="space-y-2 text-xs text-gray-500 font-semibold">
          <li>
            <a
              href="/terms-and-conditions"
              class="hover:text-white transition-colors duration-150"
              >Terms of Use</a
            >
          </li>
          <li>
            <a
              href="/privacy-policy"
              class="hover:text-white transition-colors duration-150"
              >Privacy Policy</a
            >
          </li>
          <li>
            <a
              href="/about"
              class="hover:text-white transition-colors duration-150"
              >About Us</a
            >
          </li>
          <li>
            <a
              href="/contact"
              class="hover:text-white transition-colors duration-150"
              >Contact Us</a
            >
          </li>
        </ul>
      </div>
      <div class="space-y-4">
        <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400">
          Newsletter
        </h4>
        <p class="text-xs text-gray-500">
          Subscribe for a daily dose of verified high-impact ideas.
        </p>
        <div
          class="flex border border-gray-800 focus-within:border-[#EB0028] transition-colors duration-150"
        >
          <input
            type="email"
            placeholder="Your email address"
            class="bg-[#1A1A1A] text-white px-3 py-2 text-xs w-full focus:outline-none placeholder-gray-500"
            disabled
          />
          <button
            class="bg-[#EB0028] text-white font-bold uppercase text-[10px] tracking-wider px-4 py-2 hover:bg-[#c40020] opacity-80 cursor-not-allowed"
            disabled
          >
            Subscribe
          </button>
        </div>
      </div>
    </div>
    <div
      class="max-w-7xl mx-auto mt-8 sm:mt-12 pt-5 sm:pt-6 border-t border-gray-900 flex flex-col sm:flex-row justify-between items-center text-[10px] sm:text-xs text-gray-600 gap-3 sm:gap-4 text-center sm:text-left"
    >
      <div>
        &copy; 2026 TED Talk Finder. Built with Astro &amp; Tailwind CSS v4.
      </div>
      <div class="flex space-x-3 sm:space-x-4">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors duration-150">GitHub</a
        >
        <a
          href="https://developers.google.com/youtube/v3"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors duration-150">YouTube API</a
        >
        <a
          href="https://docs.astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors duration-150">Astro Docs</a
        >
      </div>
    </div>
  </footer>
</Layout>

<script>
  // Backend URL configuration
  const BACKEND_URL =
    (import.meta as any).env.PUBLIC_BACKEND_URL || "http://localhost:3001";

  // DOM Elements
  const form = document.getElementById("search-form") as HTMLFormElement;
  const input = document.getElementById("search-input") as HTMLInputElement;
  const searchBtn = document.getElementById("search-btn") as HTMLButtonElement;

  const initialState = document.getElementById(
    "initial-state",
  ) as HTMLDivElement;
  const loadingState = document.getElementById(
    "loading-state",
  ) as HTMLDivElement;
  const errorState = document.getElementById("error-state") as HTMLDivElement;
  const errorText = document.getElementById(
    "error-text",
  ) as HTMLParagraphElement;
  const successState = document.getElementById(
    "success-state",
  ) as HTMLDivElement;

  const resultsTitle = document.getElementById(
    "results-title",
  ) as HTMLHeadingElement;
  const resultsGrid = document.getElementById("results-grid") as HTMLDivElement;
  const recentSection = document.getElementById(
    "recent-section",
  ) as HTMLDivElement;
  const recentGrid = document.getElementById("recent-grid") as HTMLDivElement;
  const homepageRecent = document.getElementById(
    "homepage-recent",
  ) as HTMLDivElement;
  const homepageRecentGrid = document.getElementById(
    "homepage-recent-grid",
  ) as HTMLDivElement;
  const retryBtn = document.getElementById("retry-btn") as HTMLButtonElement;
  const showMoreBtn = document.getElementById(
    "show-more-btn",
  ) as HTMLButtonElement;
  const tagButtons = document.querySelectorAll(".tag-btn");

  // Pagination state
  let allTalks: any[] = [];
  let displayedCount = 0;
  const TALKS_PER_PAGE = 6;

  // Tag buttons only fill the input — user still has to click Find Talks
  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      input.value = (btn.textContent || "").trim();
      input.focus();
    });
  });

  retryBtn.addEventListener("click", () => {
    if (input.value.trim()) {
      performSearch(input.value);
    }
  });

  // Trigger on button click OR Enter key
  searchBtn.addEventListener("click", () => {
    performSearch(input.value);
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    performSearch(input.value);
  });

  async function performSearch(topic: string) {
    if (!topic || !topic.trim()) return;

    // Scroll down to the results/loading section
    document
      .getElementById("results-section")
      ?.scrollIntoView({ behavior: "smooth", block: "start" });
    const loadingKeyword = document.getElementById("loading-keyword");
    if (loadingKeyword) {
      const t = topic.trim();
      loadingKeyword.textContent = t.charAt(0).toUpperCase() + t.slice(1);
    }

    // Reset UI State to loading
    showState("loading");
    searchBtn.disabled = true;

    try {
      const response = await fetch(`${BACKEND_URL}/api/find-talks`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ topic: topic.trim() }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || `Server error (${response.status})`);
      }

      renderResults(data);
    } catch (err: any) {
      console.error("Search failed:", err);
      errorText.textContent =
        err.message ||
        "Couldn't connect to server or verify talks — try a different topic.";
      showState("error");
    } finally {
      searchBtn.disabled = false;
    }
  }

  function showState(state: "initial" | "loading" | "error" | "success") {
    initialState.classList.add("hidden");
    homepageRecent.classList.add("hidden");
    loadingState.classList.add("hidden");
    errorState.classList.add("hidden");
    successState.classList.add("hidden");

    if (state === "initial") {
      initialState.classList.remove("hidden");
      homepageRecent.classList.remove("hidden");
    } else if (state === "loading") loadingState.classList.remove("hidden");
    else if (state === "error") errorState.classList.remove("hidden");
    else if (state === "success") successState.classList.remove("hidden");
  }

  // Trigger pagination load
  showMoreBtn.addEventListener("click", () => {
    renderNextPage();
  });

  function renderResults(data: {
    topic: string;
    results?: any[];
    recentResults?: any[];
  }) {
    allTalks = data.results || [];
    displayedCount = 0;
    resultsGrid.innerHTML = "";
    recentGrid.innerHTML = "";

    // Set Header Title
    resultsTitle.textContent = `Talks about "${data.topic}"`;

    // Render first page of 6 curated talks
    renderNextPage();

    // Render recent uploads
    const recentTalks = data.recentResults || [];
    if (recentTalks.length > 0) {
      recentSection.classList.remove("hidden");
      recentTalks.forEach((talk: any) => {
        const card = createCardElement(talk);
        recentGrid.appendChild(card);
      });
    } else {
      recentSection.classList.add("hidden");
    }

    showState("success");
  }

  function getRelativeTimeString(dateStr: string): string {
    if (!dateStr) return "";
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return "";
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();

    const diffSecs = Math.floor(diffMs / 1000);
    const diffMins = Math.floor(diffSecs / 60);
    const diffHours = Math.floor(diffMins / 60);
    const diffDays = Math.floor(diffHours / 24);
    const diffMonths = Math.floor(diffDays / 30.44);
    const diffYears = Math.floor(diffDays / 365.25);

    if (diffYears > 0) {
      return diffYears === 1 ? "1 yr ago" : `${diffYears} yrs ago`;
    }
    if (diffMonths > 0) {
      return diffMonths === 1 ? "1 mo ago" : `${diffMonths} mos ago`;
    }
    if (diffDays > 0) {
      return diffDays === 1 ? "1 day ago" : `${diffDays} days ago`;
    }
    return "Recently";
  }

  // Decoder element to handle YouTube API HTML entities
  const decoderEl = document.createElement("textarea");
  function escapeHtml(str: string): string {
    if (!str) return "";
    decoderEl.innerHTML = str;
    return decoderEl.value
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function createCardElement(talk: any): HTMLDivElement {
    const card = document.createElement("div");

    card.className =
      "bg-white border border-gray-200 flex flex-col h-full hover:scale-[1.02] hover:border-gray-400 transition-all duration-200 ease-out group";
    card.innerHTML = `
      <div class="aspect-video w-full bg-black relative overflow-hidden">
        <img 
          src="${escapeHtml(talk.thumbnail)}" 
          alt="${escapeHtml(talk.title)}"
          class="w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-150"
          loading="lazy"
        />
        <div class="absolute bottom-2 right-2 bg-black/80 px-1.5 py-0.5 text-[9px] sm:text-[10px] font-bold text-white uppercase tracking-wider">
          ${escapeHtml(talk.duration)}
        </div>
        <!-- Hover Play Overlay -->
        <div class="absolute inset-0 bg-[#EB0028]/25 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity duration-150">
          <div class="bg-[#EB0028] text-white p-2.5 sm:p-3 rounded-full shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6 fill-current" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      </div>
      <div class="p-4 sm:p-6 flex flex-col flex-grow">
        <div class="flex justify-between items-center mb-1 sm:mb-1.5 gap-2">
          <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-widest text-[#EB0028] truncate">${escapeHtml(talk.speaker)}</span>
          ${talk.publishedAt ? `<span class="text-[9px] sm:text-[10px] text-gray-500 font-semibold uppercase tracking-wider shrink-0">${escapeHtml(getRelativeTimeString(talk.publishedAt))}</span>` : ""}
        </div>
        <h3 class="text-sm sm:text-base md:text-lg font-bold text-gray-900 leading-tight mb-2 sm:mb-3 line-clamp-2 uppercase">
          ${escapeHtml(talk.title)}
        </h3>
        <p class="text-xs sm:text-sm text-gray-600 font-normal leading-relaxed mb-4 sm:mb-6 line-clamp-3">
          ${escapeHtml(talk.reason)}
        </p>
        <a 
          href="${escapeHtml(talk.youtubeLink)}" 
          target="_blank" 
          rel="noopener noreferrer"
          class="mt-auto w-full bg-black text-white text-center py-2.5 sm:py-3 text-[11px] sm:text-xs font-bold uppercase tracking-wider hover:bg-[#EB0028] transition-colors duration-150"
        >
          Watch on YouTube
        </a>
      </div>
    `;
    return card;
  }

  function renderNextPage() {
    const nextBatch = allTalks.slice(
      displayedCount,
      displayedCount + TALKS_PER_PAGE,
    );

    nextBatch.forEach((talk: any) => {
      const card = createCardElement(talk);
      resultsGrid.appendChild(card);
    });

    displayedCount += nextBatch.length;

    // Show/Hide Show More button
    if (displayedCount >= allTalks.length) {
      showMoreBtn.classList.add("hidden");
    } else {
      showMoreBtn.classList.remove("hidden");
    }
  }

  // Fetch featured recent uploads on page load
  async function loadFeaturedTalks() {
    try {
      const response = await fetch(`${BACKEND_URL}/api/recent-uploads`);
      if (!response.ok) throw new Error("Failed to load");
      const data = await response.json();
      const results = data.results || [];

      homepageRecentGrid.innerHTML = "";

      if (results.length === 0) {
        homepageRecentGrid.innerHTML = `<div class="text-center py-12 text-gray-400 col-span-full">No recent talks available.</div>`;
        return;
      }

      results.forEach((talk: any) => {
        const card = createCardElement(talk);
        homepageRecentGrid.appendChild(card);
      });
    } catch (err) {
      console.error("Failed to load featured talks:", err);
      homepageRecentGrid.innerHTML = `<div class="text-center py-12 text-gray-400 col-span-full">Unable to load featured recent talks.</div>`;
    }
  }

  // Call on load
  loadFeaturedTalks();
</script>
