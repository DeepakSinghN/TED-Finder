# =========================================================================
# FIND TED TALKS — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' and fill in your actual API keys.
# =========================================================================

# Backend Server Configuration
PORT=3001

# AI API Keys (Configure at least one)
# -------------------------------------------------------------------------
# Google Gemini API Key (Get a free key from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key (Get a key from Anthropic Console)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API Key
# -------------------------------------------------------------------------
# Get a key by enabling the "YouTube Data API v3" in Google Cloud Console
YOUTUBE_API_KEY=your_youtube_api_key_here

# Frontend Configuration
# -------------------------------------------------------------------------
# Points Astro client-side fetching to the Express server.
# For local dev, this defaults to http://localhost:3001 if omitted.
PUBLIC_BACKEND_URL=http://localhost:3001
